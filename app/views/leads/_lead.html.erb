<div id="<%= dom_id(lead) %>" class="card mb-4 border-0 shadow-sm rounded-4">
  <div class="card-body p-4">
    <div class="d-flex justify-content-between align-items-start mb-3">
      <div>
        <h5 class="card-title fw-bold mb-1 text-dark"><%= lead.name %></h5>
        <h6 class="card-subtitle text-muted mb-0"><%= lead.email %></h6>
      </div>
      <div>
        <span class="badge rounded-pill px-3 py-2 <%= lead.ai_status == 'completed' ? 'bg-success-subtle text-success border border-success-subtle' : lead.ai_status == 'failed' ? 'bg-danger-subtle text-danger border border-danger-subtle' : 'bg-warning-subtle text-warning border border-warning-subtle' %>" style="font-size: 0.85rem;">
          <%= lead.ai_status&.capitalize || 'Pending' %>
        </span>
      </div>
    </div>

    <p class="card-text text-secondary bg-light p-3 rounded-3 mb-3 border-start border-4 border-secondary-subtle" style="font-style: italic;">
      "<%= lead.message %>"
    </p>

    <% if lead.summary.present? %>
      <div class="pt-3 border-top mt-3">
        <h6 class="fw-bold text-uppercase text-muted mb-3" style="font-size: 0.75rem; letter-spacing: 0.05em;">AI Lead Analysis</h6>
        
        <div class="row g-3">
          <div class="col-12 col-md-6">
            <div class="p-3 bg-light rounded-3 h-100">
              <span class="text-muted d-block mb-1" style="font-size: 0.85rem;">Summary</span>
              <p class="mb-0 text-dark" style="font-size: 0.95rem; line-height: 1.5;"><%= lead.summary %></p>
            </div>
          </div>
          
          <div class="col-12 col-md-6">
            <div class="row g-2 h-100">
              <div class="col-6">
                <div class="p-3 bg-light rounded-3 text-center h-100 d-flex flex-column justify-content-center align-items-center">
                  <span class="text-muted d-block mb-1" style="font-size: 0.85rem;">Lead Score</span>
                  <span class="fs-4 fw-bold text-primary"><%= lead.lead_score %>/10</span>
                </div>
              </div>
              <div class="col-6">
                <div class="p-3 bg-light rounded-3 text-center h-100 d-flex flex-column justify-content-center align-items-center">
                  <span class="text-muted d-block mb-1" style="font-size: 0.85rem;">Intent & Urgency</span>
                  <div class="d-flex flex-wrap gap-1 justify-content-center mt-1">
                    <span class="badge px-3 py-2 <%= lead.intent == 'hot' ? 'bg-danger-subtle text-danger border border-danger-subtle' : lead.intent == 'warm' ? 'bg-warning-subtle text-warning border border-warning-subtle' : 'bg-info-subtle text-info border border-info-subtle' %>" style="font-size: 0.75rem; text-transform: uppercase;">
                      <%= lead.intent %>
                    </span>
                    <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-3 py-2" style="font-size: 0.75rem;">
                      <%= lead.urgency %>
                    </span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>